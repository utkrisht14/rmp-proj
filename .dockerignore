# Git and editor files are not needed inside the Docker image.
.git
.idea

# Local Python environments and caches should never be copied into the image.
.venv
.uv-cache
.uv-python
.uv-tools
__pycache__
*.pyc
.pytest_cache

# Test files are useful locally and in Cloud Build, but not in the runtime image.
tests

# Local SQLite data should not be baked into the Docker image.
employees.db
*.db
*.sqlite
*.sqlite3

# Reports/artifacts generated by lint and test steps.
flake_reports
pytest_reports
htmlcov
.coverage

# Local-only files.
.env
.env.*
